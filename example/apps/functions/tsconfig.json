{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "$configs/*": ["./src/configs/*"],
      "$logger": ["./src/configs/logging.ts"],
      "@shared/utils": ["../../packages/utils/src"],
      "@shared/utils/*": ["../../packages/utils/src/lib/*"]
    }
  },
  "include": ["src/**/*", "scripts/**/*", "functions-cache.ts"],
  "exclude": ["node_modules", "dist"]
}
