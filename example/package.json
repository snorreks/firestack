{
  "name": "firestack-example",
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "moon": "moon",
    "build": "moon run firebase:build --",
    "deploy": "moon run firebase:deploy --",
    "delete": "moon run firebase:delete --",
    "emulate": "moon run firebase:emulate --",
    "rules": "moon run firebase:rules --",
    "scripts": "moon run firebase:scripts --",
    "logs": "moon run firebase:logs --",
    "check": "moon run :check --",
    "fix": "moon run :fix --",
    "test": "bun test tests",
    "sync": "cd .. && bun run build && cd example/apps/firebase && bun install && cd ../../packages/types && bun install"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@moonrepo/cli": "^2.2.6",
    "@biomejs/biome": "^2.4.16"
  },
  "dependencies": {
    "latest": "^0.2.0",
    "zod": "^4.4.3"
  }
}
