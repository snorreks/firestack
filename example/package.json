{
  "name": "firestack-example",
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "cd apps/firebase && bun run build",
    "deploy": "cd apps/firebase && bun run deploy",
    "delete": "cd apps/firebase && bun run delete",
    "emulate": "cd apps/firebase && bun run emulate",
    "rules": "cd apps/firebase && bun run rules",
    "scripts": "cd apps/firebase && bun run scripts",
    "logs": "cd apps/firebase && bun run logs",
    "check": "bun run --filter '*' check",
    "fix": "bun run --filter '*' fix",
    "test": "bun test tests/*.test.ts",
    "test:rules": "cd apps/firebase && bun run test:rules",
    "test:all": "bun run test && bun run test:rules",
    "sync": "cd .. && bun run build && cd example/apps/firebase && bun install && cd ../../packages/types && bun install"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@biomejs/biome": "^2.5.1"
  },
  "dependencies": {
    "latest": "^0.2.0",
    "zod": "^4.4.3"
  }
}
