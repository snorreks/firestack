{
  "name": "firestack-example",
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "moon": "moon",
    "build": "PROTO_HOME=/tmp/non-existent-proto moon run functions:build --",
    "deploy": "moon run functions:deploy --",
    "delete": "PROTO_HOME=/tmp/non-existent-proto moon run functions:delete --",
    "emulate": "PROTO_HOME=/tmp/non-existent-proto moon run functions:emulate --",
    "rules": "PROTO_HOME=/tmp/non-existent-proto moon run functions:rules --",
    "scripts": "PROTO_HOME=/tmp/non-existent-proto moon run functions:scripts --",
    "logs": "PROTO_HOME=/tmp/non-existent-proto moon run functions:logs --",
    "check": "PROTO_HOME=/tmp/non-existent-proto moon run :check --",
    "fix": "PROTO_HOME=/tmp/non-existent-proto moon run :fix --",
    "test": "bun test tests/cli.test.ts",
    "sync": "cd .. && bun run build && cd example/apps/functions && bun install && cd ../../packages/types && bun install"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@moonrepo/cli": "^2.0.4",
    "@biomejs/biome": "^2.4.6"
  }
}
