{
  "name": "firestack-example",
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "moon": "moon",
    "build": "moon run functions:build --",
    "deploy": "moon run functions:deploy --",
    "delete": "moon run functions:delete --",
    "emulate": "moon run functions:emulate --",
    "rules": "moon run functions:rules --",
    "scripts": "moon run functions:scripts --",
    "logs": "moon run functions:logs --",
    "check": "moon run :check --",
    "fix": "moon run :fix --",
    "test": "bun test tests",
    "sync": "cd .. && bun run build && cd example/apps/functions && bun install && cd ../../packages/types && bun install"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@moonrepo/cli": "^2.2.2",
    "@biomejs/biome": "^2.4.12"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
