{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Firestack Configuration",
  "description": "Configuration schema for firestack.json",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Path to the firestack.schema.json"
    },
    "functionsDirectory": {
      "type": "string",
      "default": "src/controllers",
      "description": "Directory where your function controllers are located."
    },
    "rulesDirectory": {
      "type": "string",
      "default": "src/rules",
      "description": "Directory containing Firestore/Storage rules and indexes."
    },
    "firestoreRules": {
      "type": "string",
      "description": "Specific path to firestore.rules file."
    },
    "storageRules": {
      "type": "string",
      "description": "Specific path to storage.rules file."
    },
    "scriptsDirectory": {
      "type": "string",
      "default": "scripts",
      "description": "Directory for custom maintenance/initialization scripts."
    },
    "initScript": {
      "type": "string",
      "default": "on_emulate.ts",
      "description": "Script to run automatically when starting the emulator."
    },
    "flavors": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Map of flavor names to Firebase project IDs."
    },
    "region": {
      "type": "string",
      "default": "us-central1",
      "enum": [
        "us-central1",
        "us-east1",
        "us-east4",
        "us-west1",
        "us-west2",
        "us-west3",
        "us-west4",
        "northamerica-northeast1",
        "southamerica-east1",
        "europe-central2",
        "europe-north1",
        "europe-southwest1",
        "europe-west1",
        "europe-west2",
        "europe-west3",
        "europe-west4",
        "europe-west6",
        "europe-west8",
        "europe-west9",
        "asia-east1",
        "asia-east2",
        "asia-northeast1",
        "asia-northeast2",
        "asia-northeast3",
        "asia-southeast1",
        "asia-southeast2",
        "asia-south1",
        "australia-southeast1",
        "me-west1",
        "me-central1",
        "africa-south1"
      ],
      "description": "Default region for all deployed functions."
    },
    "nodeVersion": {
      "type": "string",
      "enum": ["18", "20", "22", "24"],
      "default": "22",
      "description": "Node.js runtime version for Cloud Functions."
    },
    "engine": {
      "type": "string",
      "enum": ["bun", "node"],
      "default": "bun",
      "description": "The execution engine for running scripts."
    },
    "minify": {
      "type": "boolean",
      "default": true,
      "description": "Whether to minify the bundled function code."
    },
    "sourcemap": {
      "type": "boolean",
      "default": true,
      "description": "Whether to generate sourcemaps."
    },
    "external": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Dependencies to treat as external (installed in the function env)."
    },
    "packageManager": {
      "type": "string",
      "enum": ["npm", "yarn", "pnpm", "bun", "global"],
      "default": "global",
      "description": "The package manager for firebase commands."
    },
    "emulators": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "auth",
          "functions",
          "firestore",
          "database",
          "hosting",
          "pubsub",
          "storage",
          "eventarc",
          "extensions",
          "ui",
          "hub",
          "logging",
          "appcheck"
        ]
      },
      "description": "List of emulators to enable during emulation."
    },
    "emulatorPorts": {
      "type": "object",
      "properties": {
        "auth": { "type": "integer" },
        "functions": { "type": "integer" },
        "firestore": { "type": "integer" },
        "database": { "type": "integer" },
        "hosting": { "type": "integer" },
        "pubsub": { "type": "integer" },
        "storage": { "type": "integer" },
        "eventarc": { "type": "integer" },
        "extensions": { "type": "integer" },
        "ui": { "type": "integer" },
        "hub": { "type": "integer" },
        "logging": { "type": "integer" },
        "appcheck": { "type": "integer" }
      },
      "additionalProperties": false,
      "description": "Custom ports for individual emulators (e.g., { \"auth\": 9099 })."
    },
    "keepNames": {
      "type": "boolean",
      "default": false,
      "description": "Whether to keep original function names in the bundled code (useful for debugging)."
    }
  },
  "additionalProperties": false
}
