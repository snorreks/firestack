{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "lib": ["ESNext"],
    "baseUrl": ".",
    "paths": {
      "$lib/*": ["src/lib/*"],
      "$constants": ["src/lib/constants/index.ts"],
      "$commands/*": ["src/lib/commands/*"],
      "$helpers/*": ["src/lib/helpers/*"],
      "$types": ["src/lib/types/index.ts"],
      "$utils/*": ["src/lib/utils/*"],
      "$logger": ["src/lib/utils/logger.js"]
    }
  },
  "include": ["src"]
}
