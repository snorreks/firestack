{
  "name": "@snorreks/firestack",
  "version": "0.0.29",
  "description": "CLI tool for deploying Firebase Cloud Functions with ease",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "bin": {
    "firestack": "main.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/snorreks/firestack.git"
  },
  "bugs": {
    "url": "https://github.com/snorreks/firestack/issues"
  },
  "homepage": "https://github.com/snorreks/firestack#readme",
  "scripts": {
    "build": "bun run ./build.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "fix": "biome check --write .",
    "check": "tsc --noEmit",
    "test": "cd example && bun run build && bun test tests",
    "publish": "bun run ./build.ts && cd dist && npm publish --access public"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "esbuild": "^0.27.4",
    "execa": "^9.6.1",
    "firebase-functions": "^7.1.1",
    "firebase-tools": "^15.10.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/bun": "^1.3.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "firebase",
    "cloud-functions",
    "google-cloud-functions",
    "serverless",
    "gcp",
    "deploy",
    "typescript",
    "esbuild",
    "gemini-cli",
    "dx"
  ],
  "author": "Snorreks",
  "license": "MIT",
  "sideEffects": false
}
